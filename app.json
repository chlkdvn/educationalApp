{
  "expo": {
    "name": "edu",
    "slug": "edu-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/cardzip-icon.png",
    "scheme": "cardzipapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to take photos of gift cards",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to select gift card images",
        "NSPhotoLibraryAddUsageDescription": "We need access to save photos to your library if necessary"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/cardzip-icon.png",
        "backgroundImage": "./assets/images/cardzip-icon.png",
        "monochromeImage": "./assets/images/cardzip-icon.png"
      },
      "notification": {
        "icon": "./assets/images/notification-icon.png",
        "color": "#000000",
        "channelId": "default"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.deracali.cardzipapp",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/cardzip-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/cardzip-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    },
    "owner": "deracali"
  }
}
